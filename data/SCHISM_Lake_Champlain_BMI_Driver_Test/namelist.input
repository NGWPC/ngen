&test                                               ! BMI configuration specs
  model_start_time   = 0                            ! Time start of simulation in seconds
  model_end_time     = 5000.0                       ! Time end of simulation in seconds
  num_time_steps     = 2                            ! Number of time steps to run BMI model for
  time_step_size     = 3600                         ! timestep [seconds]
  SCHISM_dir         = "./"                         ! SCHISM directory for configuration and forcing files
  SCHISM_NSCRIBES    = 0                            ! Number of processors to dedicate to I/O methods. In serial mode, this must be 0 and SCHISM "OLD IO" option must be selected for compiling. If SCHISM BMI is executed in parallel, then this number can be greater than zero to dedicated and speed up I/O methods. If implemented, then SCHISM "OLD IO" option must be turned off.
/
